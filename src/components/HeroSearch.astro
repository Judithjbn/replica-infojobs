---
import SearchIcon from '@icons/Search.astro'
import { getStudyLevels } from '@lib/study-levels'

const SHORTCUTS = [
    {
        label: 'Sin experiencia',
        href: '/sin-experiencia',
    },
    {
        label: 'Findes',
        href: '/findes',
    },
    {
        label: 'Trabajo remoto',
        href: '/trabajo-remoto',
    },
    {
        label: 'Media jornada',
        href: '/media-jornada',
    },
] as const

const studyLevels = await getStudyLevels()
---

<section class="mx-auto max-w-7xl px-4 w-full">
    <div class="bg-hero-pattern bg-cover mx-auto w-full rounded-3xl px-4 py-6">
        <h1 class=" text-black/80 font-semibold traking-[0.35px] text-2xl text-center pb-4">Tu carrera empieza aquí</h1>
        <search class="bg-white rounded-3xl p-4">
            <div>
                <select name="" id="" class="w-full py-4 border-b border-gray-300 text-gray-600">
                    <option value="" disabled selected>Nivel de estudios</option>
                    {studyLevels.map((level) => 
                        <option value="{level.id}">{level.label}</option>
                    )}
                </select>
            </div>
            <div>
                <input placeholder="Estudios, puesto, empresa..."
                class="w-full py-4 border-b border-gray-300 text-gray-600">
            </div>
            <div class="mb-8">
                <input placeholder="Provincia o población"
                class="w-full py-4 border-b border-gray-300 text-gray-600">
            </div>
            <form action=""></form>
            <button class="text-lg font-medium bg-accent hover:contrast-150 text-white rounded-full py-2 px-4 inline-flex items-center justify-center gap-x-2 w-full">
                <SearchIcon />
                Buscar ofertas</button>
        </search>

        <footer>
            
                <h5 class="text-center pt-8 pb-4">Explora trabajos que se adaptan a ti</h5>
                <div class="flex flex-wrap gap-4 justify-center items-center">
                    {
                        SHORTCUTS.map(({label, href})=>(
                            <a href={href} class=" bg-white p-4 rounded-full text-primary text-regular">{label}</a>
                        )) 
                    }
            </div>    
        </footer>
        
    </div>
</section> 